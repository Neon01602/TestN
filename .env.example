# Forge Backend — Environment Variables
# Copy this file to .env and fill in real values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In development, leave blank to allow all origins
# In production, set to your deployed frontend URL(s)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ─── Security ─────────────────────────────────────────────────────────────────
# Optional: shared secret for protecting /incidents/ingest from external callers
# API_SECRET=change-me-in-production

# ─── Auto-Ingest ──────────────────────────────────────────────────────────────
# Interval in milliseconds for simulated error auto-ingestion (default: 45000)
# AUTO_INGEST_INTERVAL_MS=45000

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# The backend URL your frontend will connect to.
# Set in frontend/.env (not here).
# VITE_API_URL=http://localhost:3000
